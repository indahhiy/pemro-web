<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Biodata Mahasiswa</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f0f2f5;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            width: 350px;
        }

        /* Kolom untuk judul */
        .judul {
            border: 2px solid #4CAF50;
            padding: 10px;
            text-align: center;
            font-size: 22px;
            font-weight: bold;
            border-radius: 8px;
            color: #4CAF50;
            margin-bottom: 15px;
            background-color: #e8f5e9;
        }

        p {
            margin: 8px 0;
        }
    </style>
</head>

<body>

<div class="container">
    <div class="judul">Biodata Mahasiswa</div>

    <p>Nama: Fandi Kurnniawan</p>
    <p>Kelas: Karyawan</p>
    <p>Jurusan: Rekayasa Perangkat Lunak</p>
    <p>Alamat: Banjarbaru</p>
    <p>Hobi: Membaca dan Bermain Bola</p>
</div>

</body>
</html>
